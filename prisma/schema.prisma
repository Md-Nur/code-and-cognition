generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Core User model representing both administrators and contractors.
model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role                @default(CONTRACTOR)
  createdAt          DateTime            @default(now())
  activityLogs       ActivityLog[]
  changeRequests     ChangeRequest[]
  ledgerBalance      LedgerBalance?
  ledgerEntries      LedgerEntry[]
  notifications      Notification[]
  projects           Project[]           @relation("ClientProject")
  finderProjects     Project[]           @relation("ProjectFinder")
  memberProjects     ProjectMember[]
  withdrawals        Withdrawal[]
  proposedExpenses   Expense[]           @relation("ExpenseProposer")
  expenseApprovals   ExpenseApproval[]
  companyShares      CompanyShare[]
  coFounderProposals CoFounderProposal[] @relation("Proposee")
  proposalsMade      CoFounderProposal[] @relation("Proposer")
  coFounderApprovals CoFounderApproval[]
  isCFO              Boolean             @default(false)
}

/// Tracks company ownership distribution and lock-in periods.
model CompanyShare {
  id          String   @id @default(cuid())
  userId      String
  percentage  Float
  grantedAt   DateTime @default(now())
  lockedUntil DateTime
  note        String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Workflow for transitioning a contractor to a co-founder.
model CoFounderProposal {
  id          String              @id @default(cuid())
  proposerId  String
  userId      String
  targetShare Float
  status      ProposalStatus      @default(DRAFT)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  proposer    User                @relation("Proposer", fields: [proposerId], references: [id])
  user        User                @relation("Proposee", fields: [userId], references: [id])
  approvals   CoFounderApproval[]

  @@index([userId])
}

model CoFounderApproval {
  id         String            @id @default(cuid())
  proposalId String
  userId     String
  status     VoteStatus        @default(APPROVED)
  createdAt  DateTime          @default(now())
  proposal   CoFounderProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
}

/// Secure, short-lived tokens for passwordless client login.
model MagicToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

/// High-level service categories for organizing offerings (e.g., Digital Platforms, Brand Strategy)
model ServiceCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  slug        String    @unique
  order       Int       @default(0)
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
}

/// Main service offerings with business value positioning and overview
model Service {
  id               String            @id @default(cuid())
  categoryId       String
  title            String            @unique
  slug             String            @unique
  /// Technical description
  description      String
  /// High-level service overview
  overview         String?
  /// Business value and strategic positioning
  positioningText  String?
  status           Status            @default(ACTIVE)
  thumbnailUrl     String?
  order            Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bookings         Booking[]
  engagementModels EngagementModel[]
  portfolioItems   PortfolioItem[]
  category         ServiceCategory   @relation(fields: [categoryId], references: [id])
}

/// Flexible engagement models for services (Strategy | Implementation | Optimization | Retainer)
model EngagementModel {
  id            String      @id @default(cuid())
  serviceId     String
  /// e.g., Strategy, Implementation, Optimization, Retainer
  name          String
  description   String
  pricingType   PricingType @default(CUSTOM)
  /// Nullable for custom pricing
  basePriceBDT  Float?
  /// Nullable for custom pricing
  basePriceUSD  Float?
  /// List of key deliverables
  deliverables  String[]
  /// Estimated timeline in days
  estimatedDays Int?
  order         Int         @default(0)
  status        Status      @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  proposals     Proposal[]

  @@unique([serviceId, name])
}

/// Individual portfolio pieces shown in the portfolio section.
model PortfolioItem {
  id           String   @id @default(cuid())
  title        String
  description  String
  imageUrl     String?
  projectUrl   String?
  serviceId    String
  technologies String[]
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  service      Service  @relation(fields: [serviceId], references: [id])
}

/// Client bookings/leads submitted from the contact or service forms.
model Booking {
  id          String        @id @default(cuid())
  clientName  String
  clientEmail String
  clientPhone String?
  serviceId   String?
  budgetBDT   Float?
  budgetUSD   Float?
  status      BookingStatus @default(NEW)
  createdAt   DateTime      @default(now())
  /// Structured discovery data: { companyName, role, industry, revenueRange, budgetRange, problemStatement, timeline, etc. }
  discovery   Json?
  proposalId  String?       @unique
  proposal    Proposal?     @relation(fields: [proposalId], references: [id])
  service     Service?      @relation(fields: [serviceId], references: [id])
  project     Project?
}

/// Active projects managed by the agency, converted from bookings.
model Project {
  id               String          @id @default(cuid())
  title            String
  bookingId        String?         @unique
  /// The user who brought in the project (maintained for backward compatibility)
  finderId         String?
  status           ProjectStatus   @default(ACTIVE)
  health           ProjectHealth   @default(GREEN)
  /// Public viewing token for clients
  viewToken        String?         @unique @default(uuid())
  /// Project scope and objectives
  scope            String?
  /// Project start date
  startDate        DateTime?
  /// Project end date / deadline
  endDate          DateTime?
  /// Risk management notes
  riskNotes        String?
  createdAt        DateTime        @default(now())
  /// PENDING | ACTIVE | ARCHIVED
  workspaceStatus  String?         @default("PENDING")
  /// Internal/External workspace link (e.g. Notion, Slack, or internal)
  workspaceUrl     String?
  /// Dynamic split for company fund
  companyFundRatio Float           @default(0.10)
  /// Dynamic split for finder fee
  finderFeeRatio   Float           @default(0.20)
  clientUserId     String?
  activityLogs     ActivityLog[]
  changeRequests   ChangeRequest[]
  ledgerEntries    LedgerEntry[]
  milestones       Milestone[]
  payments         Payment[]
  booking          Booking?        @relation(fields: [bookingId], references: [id])
  clientUser       User?           @relation("ClientProject", fields: [clientUserId], references: [id])
  finder           User?           @relation("ProjectFinder", fields: [finderId], references: [id])
  members          ProjectMember[]
  proposals        Proposal[]
}

/// Contractors assigned to a project with their respective role and execution share (percentage).
model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  /// Percentage share of pool earnings
  share     Float
  role      ProjectMemberRole @default(EXECUTION)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, role])
}

/// Project proposals with custom scoping, budget, and approval workflow
model Proposal {
  id                String           @id @default(cuid())
  projectId         String?
  /// Can reference an engagement model or be fully custom
  engagementModelId String?
  /// Detailed scope of work
  scopeSummary      String
  /// List of deliverables
  deliverables      String[]
  budgetBDT         Float?
  budgetUSD         Float?
  currency          Currency         @default(BDT)
  /// Timeline estimate
  estimatedDays     Int?
  approved          Boolean          @default(false)
  approvedAt        DateTime?
  /// For proposal versioning
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  /// Milestones for delivery
  milestones        String[]
  /// DRAFT -> SENT -> APPROVED | REJECTED
  status            ProposalStatus   @default(DRAFT)
  /// Full contract text or additional legal terms
  contractText      String?
  /// Payment terms and schedules
  paymentTerms      String?
  /// Additional notes for the proposal
  notes             String?
  /// When the client signed & paid
  signedAt          DateTime?
  /// Public viewing token for clients
  viewToken         String?          @unique @default(uuid())
  booking           Booking?
  engagementModel   EngagementModel? @relation(fields: [engagementModelId], references: [id])
  project           Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Financial payments received for a project.
model Payment {
  id        String        @id @default(cuid())
  projectId String
  amountBDT Float?
  amountUSD Float?
  currency  Currency      @default(BDT)
  note      String?
  paidAt    DateTime      @default(now())
  splits    LedgerEntry[]
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Detailed ledger entries for each payment split (e.g., Company, Finder Fee, Execution).
model LedgerEntry {
  id           String      @id @default(cuid())
  paymentId    String?
  /// Null for COMPANY_FUND
  userId       String?
  type         SplitType
  amountBDT    Float?
  amountUSD    Float?
  createdAt    DateTime    @default(now())
  projectId    String?
  note         String?
  withdrawalId String?
  payment      Payment?    @relation(fields: [paymentId], references: [id])
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id])
  withdrawal   Withdrawal? @relation(fields: [withdrawalId], references: [id])
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  amount        Float
  currency      Currency         @default(BDT)
  status        WithdrawalStatus @default(PENDING)
  note          String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  ledgerEntries LedgerEntry[]
  user          User             @relation(fields: [userId], references: [id])
}

/// Running totals of earnings for each user.
model LedgerBalance {
  id       String @id @default(cuid())
  userId   String @unique
  totalBDT Float  @default(0)
  totalUSD Float  @default(0)
  user     User   @relation(fields: [userId], references: [id])
}

/// Customer testimonials displayed on the landing page.
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  content   String
  avatarUrl String?
  rating    Int      @default(5)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Partner or client logos shown in the client section.
model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Business expenses recorded for profit/revenue tracking.
model Expense {
  id           String            @id @default(cuid())
  title        String
  amountBDT    Float
  amountUSD    Float?
  category     String?
  date         DateTime          @default(now())
  note         String?
  status       ExpenseStatus     @default(PENDING)
  proposedById String?
  executedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  proposedBy   User?             @relation("ExpenseProposer", fields: [proposedById], references: [id])
  approvals    ExpenseApproval[]
}

model ExpenseApproval {
  id        String     @id @default(cuid())
  expenseId String
  userId    String
  status    VoteStatus @default(APPROVED)
  createdAt DateTime   @default(now())
  expense   Expense    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

/// Articles and thought leadership pieces for the Insights section.
model Article {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  /// Markdown or HTML content
  content      String
  /// Brief summary for grid view
  excerpt      String?
  /// e.g., AI & Automation, Product Strategy
  category     String
  thumbnailUrl String?
  isFeatured   Boolean  @default(false)
  viewCount    Int      @default(0)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

/// Project milestones for tracking progress and deliverables.
model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  order       Int             @default(0)
  status      MilestoneStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

/// Audit trail of events and actions performed on projects.
model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  userId    String?
  action    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

/// Client-initiated or founder-created change requests within a project.
model ChangeRequest {
  id                    String    @id @default(cuid())
  projectId             String
  requestedById         String
  title                 String
  description           String
  /// In hours
  estimatedTimeImpact   Float     @default(0)
  /// In project currency
  estimatedBudgetImpact Float     @default(0)
  status                CRStatus  @default(PENDING)
  clientApprovalAt      DateTime?
  createdAt             DateTime  @default(now())
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy           User      @relation(fields: [requestedById], references: [id])
}

/// Audit trail for authentication and security events.
model SecurityLog {
  id           String   @id @default(cuid())
  email        String
  /// e.g., "MAGIC_LINK_REQUEST", "MAGIC_LINK_VERIFY", "PASSWORD_LOGIN"
  action       String
  /// e.g., "SUCCESS", "FAILURE", "INVALID_ROLE", "REJECTED"
  status       String
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  fingerprint  String?
  isSuspicious Boolean  @default(false)

  @@index([email])
  @@index([action])
  @@index([ip, createdAt])
}

/// System notifications for users
model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

enum ProjectMemberRole {
  FINDER
  EXECUTION
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum Role {
  FOUNDER
  CONTRACTOR
  CLIENT
  CO_FOUNDER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PricingType {
  /// Fixed price engagement
  FIXED
  /// Custom pricing per project
  CUSTOM
  /// Monthly retainer model
  RETAINER
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum BookingStatus {
  NEW
  QUALIFIED
  PROPOSAL_SENT
  CLOSED_WON
  CLOSED_LOST
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DELIVERED
}

enum NotificationType {
  MESSAGE_NEW
  PROJECT_UPDATE
  PAYMENT_RECEIVED
  SYSTEM_ALERT
  PROPOSAL_SENT
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  BOOKING_NEW
  CHANGE_REQUEST_NEW
}

enum Currency {
  BDT
  USD
}

enum SplitType {
  COMPANY_FUND
  FINDER_FEE
  EXECUTION
  WITHDRAWAL
}

enum ProjectHealth {
  GREEN
  YELLOW
  RED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum CRStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoteStatus {
  APPROVED
  REJECTED
}
